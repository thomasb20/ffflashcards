{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ffflashcards",
  "compatibility_date": "2026-05-26",
  "main": "src/main.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "kv_namespaces": [
    {
      "binding": "ffflashcards_db",
      "id": "d4228349a29342689b10392d7916af16"
    }
  ],
  "version_metadata": {
    "binding": "CF_VERSION_METADATA"
  }
}